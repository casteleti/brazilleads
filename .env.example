# ============================================================
# BRAZILLEADS - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://brazilleads.com
NEXT_PUBLIC_APP_ENV=production

# --- Analytics ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL=XXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/brazilleads
REDIS_URL=redis://user:password@host:6379

# --- Email ---
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Google ---
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_CALENDAR_ID=primary

# --- Calendly ---
CALENDLY_API_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- RD Station ---
RD_STATION_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- WhatsApp ---
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Automation ---
N8N_WEBHOOK=https://n8n.yourdomain.com/webhook/XXXXXXXXXXXXXXXX

# --- BigQuery ---
BIGQUERY_PROJECT=brazilleads-analytics

# --- Coolify ---
COOLIFY_DEPLOY_HOOK=https://coolify.yourdomain.com/deploy/XXXXXXXX
